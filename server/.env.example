PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/eventra?retryWrites=true&w=majority
JWT_SECRET=<long-random-string>
EMAIL_USER=<your-gmail-address>
EMAIL_PASS=<gmail-app-password>
# Optional: base URL used in password-reset links. Only needed in local dev
# (set to http://localhost:5173). In production the link is derived from the request.
CLIENT_URL=
